# .env.example
# Variables de entorno para Mizu-Intelligence
# Copiar este archivo a .env y completar los valores reales

# ----------------------
# OpenAI Configuration
# ----------------------
# API Key para OpenAI (requerida)
OPENAI_API_KEY=sk-...

# Modelo de embeddings (recomendado: text-embedding-3-small por costo/rendimiento)
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# Modelo de chat (GPT-4o para mejor calidad; se puede usar gpt-4o-mini para menor costo)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Temperatura para el modelo (0.0 a 1.0; valores bajos = respuestas más determinísticas)
OPENAI_TEMPERATURE=0.3

# ----------------------
# ChromaDB Configuration
# ----------------------
# Ruta donde se persistirá la base de datos vectorial
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Nombre de la colección a utilizar
CHROMA_COLLECTION_NAME=enterprise_knowledge

# ----------------------
# Guardrails & Safety
# ----------------------
# Umbral de similitud mínimo para considerar un documento relevante (0.0 a 1.0)
# Por debajo de este valor se considera que no hay contexto suficiente
SIMILARITY_THRESHOLD=0.7

# Máximo número de chunks a recuperar en la búsqueda
RETRIEVAL_K=4

# Palabras/frases prohibidas para inputs maliciosos (separadas por coma)
FORBIDDEN_PATTERNS=ignorar instrucciones previas,olvida tu prompt,dame acceso como administrador

# ----------------------
# Application
# ----------------------
# Entorno de ejecución: development, production
APP_ENV=development

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS: orígenes permitidos (separados por coma). En desarrollo usar http://localhost:8000,http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
